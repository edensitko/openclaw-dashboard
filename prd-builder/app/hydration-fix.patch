// Wrap all Date.now() calls in useEffect or use stable IDs
// Replace: id: Date.now().toString()
// With: id: useId() or generateId()

const generateId = () => Math.random().toString(36).slice(2, 11);

// Wrap localStorage in useEffect:
const [theme, setTheme] = useState<"light" | "dark">("dark");
useEffect(() => {
  const saved = localStorage.getItem("prd-theme") as "light" | "dark" | null;
  setTheme(saved || "dark");
}, []);
